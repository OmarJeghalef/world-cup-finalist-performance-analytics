# Credentials and environment variables
.env
.env.*
!.env.example

# Python virtual environments
.venv/
venv/
env/

# Python-generated files
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/

# Jupyter
.ipynb_checkpoints/

